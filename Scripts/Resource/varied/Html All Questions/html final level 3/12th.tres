[resource]
script = ExtResource("1_fxic2")
Question_Info = "If you want to apply two different styles (like color and font-size) within one style attribute, how do you separate them?"
options = Array[String](["Use a space between them.", "Use a colon (:) between them.", "Use a semicolon (;) between them.", "Use a forward slash (/) between them."])
correct = "Use a semicolon (;) between them."
