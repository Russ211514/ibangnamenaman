script = ExtResource("1_1r43v")
Question_Info = "If you apply style=\"color: blue;\" to the <body> tag, what is the result?"
options = Array[String](["All text within the body will inherit the color blue.", "Only the page background becomes blue.", "All images on the page turn blue.", "The browser will ignore the style because it is on the body tag."])
correct = "All text within the body will inherit the color blue."
