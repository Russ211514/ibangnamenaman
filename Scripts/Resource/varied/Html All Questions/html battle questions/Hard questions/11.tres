Question_Info = "Why does a `<p>` tag always start on a new line, while a `<b>` tag stays on the same line as the rest of the text?"
options = Array[String](["Paragraphs are \"Block-level\" elements; Bold tags are \"Inline\" elements.", "Bold tags are \"Block-level\"; Paragraphs are \"Inline\".", "It depends on the browser you are using.", "The `<p>` tag is a \"Root\" element."])
