[resource]
script = ExtResource("1_oxyk0")
Question_Info = "If you apply `text-align: center;` to a paragraph, but then apply `float: right;` to an image **inside** that paragraph, where will the image go?"
options = Array[String](["It will stay in the center because of the paragraph.", "It will move to the right, ignoring the paragraph's center alignment.", "It will disappear from the screen.", "It will move to the left."])
correct = "It will move to the right, ignoring the paragraph's center alignment."
difficulty = 2
