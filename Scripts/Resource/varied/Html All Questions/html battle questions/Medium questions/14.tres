[resource]
script = ExtResource("1_hmvni")
Question_Info = "Which is the correct way to change both the color and the alignment of a paragraph in one tag?"
options = Array[String](["`<p style=\"color: red; text-align: center;\">`", "`<p style=\"color: red\" style=\"text-align: center\">`", "`<p style=\"color: red + text-align: center\">`", "`<p style=\"color: red: text-align: center:\">`"])
correct = "`<p style=\"color: red; text-align: center;\">`"
difficulty = 1
