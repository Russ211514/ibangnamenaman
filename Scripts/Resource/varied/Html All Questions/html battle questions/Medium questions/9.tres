[resource]
script = ExtResource("1_shjxj")
Question_Info = "What happens to a webpage if a developer forgets to add the `</a>` closing tag after a link?"
options = Array[String](["The link will not work at all.", "Only the first word of the link will be clickable.", "All following content on the page may become part of the clickable link.", "The browser will automatically delete the text."])
correct = "All following content on the page may become part of the clickable link."
difficulty = 1
