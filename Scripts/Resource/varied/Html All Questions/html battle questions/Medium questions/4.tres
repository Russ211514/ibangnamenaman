[resource]
script = ExtResource("1_ff3r6")
Question_Info = "You are linking to a website you don't own (like a search engine). What must you include in your `href` value?"
options = Array[String](["Just the name (e.g., \"google\")", "The file name (e.g., \"google.html\")", "An absolute URL (e.g., \"[https://www.google.com](https://www.google.com)\")", "A relative path (e.g., \"/https://www.google.com/search?q=google.com\")"])
correct = "An absolute URL (e.g., \"[https://www.google.com](https://www.google.com)\")"
difficulty = 1
metadata/_custom_type_script = "uid://dwxjlf7xx3n81"
